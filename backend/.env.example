DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEFAULT_FROM_EMAIL=Mudcup <noreply@localhost>

# Customer payment QR (UPI VPA) — shown in the React app
# MUDCUP_UPI_PA=yourcafe@paytm
# MUDCUP_UPI_PAYEE_NAME=Mudcup

# Public URL of the React app (no trailing slash) — embedded in auto-generated table QRs
# FRONTEND_PUBLIC_URL=https://yourdomain.com
# Optional production email:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
